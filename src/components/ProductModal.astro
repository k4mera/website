---
const modalId = "product-modal";
---

<div
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  id={modalId}
  data-modal-backdrop
>
  <!-- Backdrop overlay -->
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" data-modal-overlay>
  </div>

  <!-- Modal content -->
  <div
    class="relative bg-custom-white rounded-lg shadow-xl w-full max-h-[90vh] overflow-y-auto z-10 md:max-w-4xl"
    data-modal-content
  >
    <!-- Close button -->
    <button
      type="button"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-custom-black hover:bg-gray-100 rounded-full transition-colors cursor-pointer z-20"
      data-modal-close
      aria-label="Close product details"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="flex flex-col md:flex-row">
      <!-- Product images carousel -->
      <div
        class="w-full md:w-1/2 shrink-0 relative overflow-hidden aspect-square rounded-t-lg md:rounded-l-lg md:rounded-tr-none p-4"
        id="modal-carousel"
      >
        <div
          class="flex transition-transform duration-300 ease-in-out h-full pb-1"
          id="modal-carousel-track"
        >
          <!-- Slides injected dynamically -->
        </div>
        <div
          class="flex justify-center gap-2 py-2 absolute bottom-0 left-0 right-0"
          id="modal-carousel-dots"
        >
          <!-- Dots injected dynamically -->
        </div>
      </div>

      <!-- Product info -->
      <div class="p-6 flex flex-col justify-between flex-1">
        <div>
          <h2
            id="modal-product-title"
            class="text-2xl font-aileron-regular mb-1"
          >
          </h2>
          <p
            id="modal-product-price"
            class="text-lg font-inter accent-blue mb-4"
          >
          </p>
          <div
            id="modal-product-description"
            class="text-sm font-inter text-custom-black mb-4 leading-relaxed"
          >
          </div>

          <!-- Variant selector (hidden if no variants) -->
          <div id="modal-variant-selector" class="mb-4 hidden">
            <label
              for="modal-variant-select"
              id="modal-variant-label"
              class="block text-sm font-inter mb-1">Option</label
            >
            <div
              id="modal-variant-options"
              class="flex flex-wrap gap-2"
            >
              <!-- Variant buttons injected dynamically -->
            </div>
          </div>

          <!-- Quantity -->
          <div class="flex items-center gap-3 mb-6">
            <label class="text-sm font-inter">Qty</label>
            <div class="flex items-center border border-gray-300 rounded">
              <button
                type="button"
                id="modal-qty-minus"
                class="px-3 py-1 hover:bg-gray-100 transition-colors cursor-pointer text-lg"
                >-</button
              >
              <span
                id="modal-qty-value"
                class="px-3 py-1 font-inter text-sm min-w-8 text-center">1</span
              >
              <button
                type="button"
                id="modal-qty-plus"
                class="px-3 py-1 hover:bg-gray-100 transition-colors cursor-pointer text-lg"
                >+</button
              >
            </div>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-col gap-2">
          <button
            type="button"
            id="modal-buy-now"
            class="w-full px-4 py-3 text-custom-white rounded-lg font-inter bg-accent-blue hover:opacity-75 transition-opacity cursor-pointer"
          >
            Buy now
          </button>
          <button
            type="button"
            id="modal-add-to-cart"
            class="w-full px-4 py-3 rounded-lg font-inter border-2 border-accent-blue accent-blue bg-transparent hover:opacity-75 transition-opacity cursor-pointer"
          >
            Add to cart
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #product-modal.open {
    display: flex;
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  #product-modal {
    opacity: 0;
    transition: opacity 0.2s ease-out;
  }

  #product-modal.open {
    opacity: 1;
  }

  [data-modal-content] {
    transform: scale(0.95) translateY(10px);
    transition:
      transform 0.2s ease-out,
      opacity 0.2s ease-out;
    opacity: 0;
  }

  #product-modal.open [data-modal-content] {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .bg-custom-white {
    background: #fffefd;
  }
</style>

<script is:inline>
  (function () {
    var carousel = document.getElementById("modal-carousel");
    var track = document.getElementById("modal-carousel-track");
    var dotsContainer = document.getElementById("modal-carousel-dots");
    var slideIndex = 0;
    var slideCount = 0;
    var autoTimer = null;

    function resetTimer() {
      clearInterval(autoTimer);
      autoTimer = null;
      if (slideCount > 1) {
        autoTimer = setInterval(function () {
          goToSlide((slideIndex + 1) % slideCount);
        }, 8000);
      }
    }

    function goToSlide(index) {
      var dots = dotsContainer.querySelectorAll("[data-dot-index]");
      if (dots[slideIndex]) {
        dots[slideIndex].classList.remove("bg-custom-black");
        dots[slideIndex].classList.add("bg-gray-400");
      }
      slideIndex = index;
      track.style.transform = "translateX(-" + slideIndex * 100 + "%)";
      if (dots[slideIndex]) {
        dots[slideIndex].classList.add("bg-custom-black");
        dots[slideIndex].classList.remove("bg-gray-400");
      }
    }

    function setImages(images, alt) {
      track.innerHTML = "";
      dotsContainer.innerHTML = "";
      slideIndex = 0;
      slideCount = images.length;

      images.forEach(function (img, i) {
        var slide = document.createElement("div");
        slide.className = "w-full shrink-0 h-full";
        var imgEl = document.createElement("img");
        imgEl.src = img.src;
        imgEl.alt = (alt || "Product") + " - " + (i + 1);
        imgEl.className = "w-full h-full object-contain";
        imgEl.draggable = false;
        slide.appendChild(imgEl);
        track.appendChild(slide);

        if (images.length > 1) {
          var dot = document.createElement("button");
          dot.className =
            "w-2 h-2 rounded-full transition-colors cursor-pointer " +
            (i === 0 ? "bg-custom-black" : "bg-gray-400");
          dot.setAttribute("data-dot-index", i);
          dot.setAttribute("aria-label", "Go to image " + (i + 1));
          dot.addEventListener("click", function () {
            goToSlide(i);
            resetTimer();
          });
          dotsContainer.appendChild(dot);
        }
      });

      dotsContainer.style.display = images.length > 1 ? "" : "none";
      track.style.transform = "translateX(0%)";
      resetTimer();
    }

    // Swipe / drag support
    var isDragging = false;
    var startX = 0;
    var currentTranslate = 0;

    carousel.addEventListener("mousedown", function (e) {
      if (e.target.closest("button, a")) return;
      isDragging = true;
      startX = e.clientX;
      track.style.transition = "none";
      carousel.style.cursor = "grabbing";
    });

    carousel.addEventListener("mousemove", function (e) {
      if (!isDragging) return;
      var diff = e.clientX - startX;
      var base = -slideIndex * 100;
      var pct = (diff / carousel.offsetWidth) * 100;
      currentTranslate = base + pct;
      track.style.transform = "translateX(" + currentTranslate + "%)";
    });

    function endDrag(e) {
      if (!isDragging) return;
      isDragging = false;
      track.style.transition = "";
      carousel.style.cursor = "";
      var diff = e.clientX - startX;
      var threshold = carousel.offsetWidth * 0.2;
      if (diff < -threshold && slideIndex < slideCount - 1) {
        goToSlide(slideIndex + 1);
      } else if (diff > threshold && slideIndex > 0) {
        goToSlide(slideIndex - 1);
      } else {
        track.style.transform = "translateX(-" + slideIndex * 100 + "%)";
      }
      resetTimer();
    }

    carousel.addEventListener("mouseup", endDrag);
    carousel.addEventListener("mouseleave", endDrag);

    carousel.addEventListener("touchstart", function (e) {
      isDragging = true;
      startX = e.touches[0].clientX;
      track.style.transition = "none";
    });

    carousel.addEventListener("touchmove", function (e) {
      if (!isDragging) return;
      var diff = e.touches[0].clientX - startX;
      var base = -slideIndex * 100;
      var pct = (diff / carousel.offsetWidth) * 100;
      currentTranslate = base + pct;
      track.style.transform = "translateX(" + currentTranslate + "%)";
    });

    carousel.addEventListener("touchend", function (e) {
      if (!isDragging) return;
      isDragging = false;
      track.style.transition = "";
      var diff = e.changedTouches[0].clientX - startX;
      var threshold = carousel.offsetWidth * 0.2;
      if (diff < -threshold && slideIndex < slideCount - 1) {
        goToSlide(slideIndex + 1);
      } else if (diff > threshold && slideIndex > 0) {
        goToSlide(slideIndex - 1);
      } else {
        track.style.transform = "translateX(-" + slideIndex * 100 + "%)";
      }
      resetTimer();
    });

    // Expose API for shop.astro
    window.modalCarousel = {
      setImages: setImages,
      goToSlide: goToSlide,
    };
  })();
</script>
