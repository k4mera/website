---
import { Image } from "astro:assets";
import logo from "../../public/assets/images/logo.png";

const { nav = "/" } = Astro.props;
---

<footer class="flex flex-col justify-between items-center w-full">
  <div class="flex justify-between w-full px-4 text-sm md:text-base font-inter">
    <div class="flex-1 flex flex-col text-left">
      <a href="/shop" class="flex-1 hover:opacity-75"> get merch </a>
      <a
        href="mailto:inquire@k4mera.world?subject=inquiry"
        class="flex-1 hover:opacity-75"
      >
        get in touch
      </a>
      <a
        href="mailto:inquire@k4mera.world?subject=💸"
        class="flex-1 hover:opacity-75"
      >
        investors
      </a>
      <a
        href="https://instagram.com/k4.mera"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 hover:opacity-75"
      >
        follow us on instagram
      </a>
      <p class="flex-1 cursor-default">designed and built by roofless labs</p>
    </div>
    <div class="flex-1 flex flex-col items-center justify-center">
      <Image src={logo} alt="K4MERA logo" class="w-24" />
    </div>
    <div class="flex-1 flex flex-col text-right">
      <a href={nav} aria-label="Go to FAQ" class="flex-1 hover:opacity-75">
        {
          () => {
            if (nav === "/") {
              return "home";
            } else if (nav === "/faq") {
              return "faq";
            }
          }
        }
      </a>
      <a
        href="https://instagram.com/k4.mera"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 hover:opacity-75"
      >
        about us
      </a>
      <a href="/terms" class="flex-1 hover:opacity-75">terms of service</a>
      <a href="/privacy" class="flex-1 hover:opacity-75">privacy</a>
      <p class="flex-1 cursor-default">© 2026 k4mera.world</p>
    </div>
  </div>
</footer>

